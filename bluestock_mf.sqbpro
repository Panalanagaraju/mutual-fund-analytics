SELECT COUNT(*) FROM dim_fund;

SELECT COUNT(*) FROM fact_nav;

SELECT COUNT(*) FROM fact_transactions;

SELECT COUNT(*) FROM fact_performance;

SELECT COUNT(*) FROM fact_aum;

PRAGMA table_info(fact_nav);

PRAGMA table_info(fact_transactions);

PRAGMA table_info(fact_performance);


SELECT
    fund_house,
    MAX(aum_crore) AS total_aum
FROM fact_aum
GROUP BY fund_house
ORDER BY total_aum DESC
LIMIT 5;


SELECT
    d.scheme_name,
    p.return_5yr_pct
FROM dim_fund d
JOIN fact_performance p
ON d.amfi_code = p.amfi_code
LIMIT 10;
</sql><current_tab id="0"/></tab_sql></sqlb_project>
